# 服务端点与大模型底座配置 (请复制此文件为 .env 并在本地填充，切勿将真实 .env 提交至 Git)

# 默认使用通用 OpenAI 规范 API，你可以根据需要修改 Base URL 接入阿里云 Qwen 或智谱 GLM-4 等。
LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
LLM_API_KEY="your_llm_api_key"
LLM_MODEL_NAME="qwen3.6-plus"
LLM_VISION_MODEL_NAME="qwen-vl-plus"
MILVUS_URI="http://localhost:19530"
AI_ENGINE_INTERNAL_TOKEN="replace_with_shared_internal_token"
